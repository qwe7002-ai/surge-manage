{
  "name": "@surge-manage/electron",
  "version": "0.1.0",
  "private": true,
  "description": "Surge Manage desktop client (Electron + React + shadcn/ui)",
  "license": "BSD-3-Clause",
  "author": {
    "name": "Surge Manage",
    "email": "noreply@example.com"
  },
  "homepage": "https://github.com/qwe7002-ai/surge-manage",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwe7002-ai/surge-manage.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "preview": "env -u ELECTRON_RUN_AS_NODE electron-vite preview",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "make-icon": "node build/make-icon.mjs",
    "prepackage": "electron-vite build",
    "package": "electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir",
    "package:mac": "electron-vite build && electron-builder --mac",
    "package:win": "electron-vite build && electron-builder --win",
    "package:linux": "electron-vite build && electron-builder --linux",
    "lint": "echo \"(eslint config omitted in scaffold)\""
  },
  "dependencies": {
    "ssh2": "^1.16.0",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@surge-manage/shared": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ssh2": "^1.15.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "lucide-react": "^0.460.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.15",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "zustand": "^5.0.1"
  }
}
