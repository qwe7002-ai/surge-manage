{
  "name": "@surge-manage/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared surge command catalog, parsers, and types",
  "license": "BSD-3-Clause",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsc -p tsconfig.json && node --test --experimental-strip-types ./src/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^5.6.3"
  }
}
